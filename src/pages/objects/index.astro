---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { getAllObjectTypes } from '../../lib/objects';

const types = await getAllObjectTypes();
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title="객체" description="영화, 감독, 단어 등 객체 목록" />
		<style>
			main {
				width: 720px;
			}
			ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			li {
				padding: 1em 0;
				border-bottom: 1px solid var(--rule);
			}
			a {
				display: flex;
				justify-content: space-between;
				text-decoration: none;
				color: inherit;
			}
			a:hover {
				color: var(--accent-bright);
			}
			.count {
				color: var(--ink-dim);
				font-family: var(--font-sans);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<ul>
				{
					types.map(({ type, count }) => (
						<li>
							<a href={`${import.meta.env.BASE_URL}objects/type/${type}/`}>
								<span>{type}</span>
								<span class="count">{count}</span>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
