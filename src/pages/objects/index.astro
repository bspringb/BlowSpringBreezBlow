---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const objects = await getCollection('objects');
const counts = new Map<string, number>();
for (const entry of objects) {
	counts.set(entry.data.type, (counts.get(entry.data.type) ?? 0) + 1);
}
const types = [...counts.entries()].sort((a, b) => a[0].localeCompare(b[0]));
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title="객체" description="영화, 감독, 단어 등 객체 목록" />
		<style>
			main {
				width: 720px;
			}
			ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			li {
				padding: 1em 0;
				border-bottom: 1px solid var(--rule);
			}
			a {
				display: flex;
				justify-content: space-between;
				text-decoration: none;
				color: inherit;
			}
			a:hover {
				color: var(--accent-bright);
			}
			.count {
				color: var(--ink-dim);
				font-family: var(--font-sans);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<ul>
				{
					types.map(([type, count]) => (
						<li>
							<a href={`${import.meta.env.BASE_URL}objects/type/${type}/`}>
								<span>{type}</span>
								<span class="count">{count}</span>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
