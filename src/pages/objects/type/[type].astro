---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';

export async function getStaticPaths() {
	const allObjects = await getCollection('objects');
	const types = [...new Set(allObjects.map((entry) => entry.data.type))];
	return types.map((type) => ({
		params: { type },
		props: {
			entries: allObjects
				.filter((entry) => entry.data.type === type)
				.sort((a, b) => a.data.title.localeCompare(b.data.title)),
		},
	}));
}

interface Props {
	entries: Awaited<ReturnType<typeof getCollection<'objects'>>>;
}

const { entries } = Astro.props;
const { type } = Astro.params;
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`${type} — 객체`} description={`${type} 타입 객체 목록`} />
		<style>
			main {
				width: 720px;
			}
			ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			li {
				padding: 1em 0;
				border-bottom: 1px solid var(--rule);
			}
			a {
				display: block;
				text-decoration: none;
				color: inherit;
			}
			a:hover .title {
				color: var(--accent-bright);
			}
			.title {
				margin: 0 0 0.2em 0;
			}
			.description {
				font-family: var(--font-serif);
				color: var(--ink-dim);
				margin: 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<ul>
				{
					entries.map((entry) => (
						<li>
							<a href={`${import.meta.env.BASE_URL}objects/${entry.id}/`}>
								<h3 class="title">{entry.data.title}</h3>
								{entry.data.description && <p class="description">{entry.data.description}</p>}
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
