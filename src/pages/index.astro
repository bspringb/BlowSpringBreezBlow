---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import CategoryGrid from '../components/react/CategoryGrid';
import Sidebar from '../components/react/Sidebar';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getAllCategories, getPostsByCategory } from '../lib/categories';
import type { HomePost } from '../lib/homeTypes';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const basePath = import.meta.env.BASE_URL;

const posts = await getCollection('blog');
const allPosts: HomePost[] = posts.map((post) => ({
	id: post.id,
	title: post.data.title,
	pubDate: post.data.pubDate.toISOString(),
}));

const categorySummaries = await getAllCategories();
const categories = await Promise.all(
	categorySummaries.map(async ({ name, count }) => {
		const categoryEntries = await getPostsByCategory(name);
		return {
			name,
			count,
			posts: categoryEntries.map((post) => ({
				id: post.id,
				title: post.data.title,
				pubDate: post.data.pubDate.toISOString(),
			})),
		};
	}),
);
const categoryPosts: Record<string, HomePost[]> = Object.fromEntries(
	categories.map((c) => [c.name, c.posts]),
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 1100px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 2em 1em;
				display: grid;
				grid-template-columns: 220px 1fr;
				gap: 3em;
				align-items: start;
			}
			@media (max-width: 800px) {
				main {
					grid-template-columns: 1fr;
				}
			}
			.category-index {
				display: flex;
				flex-wrap: wrap;
				gap: 1em;
				font-family: var(--font-sans);
				font-size: 0.85em;
				color: var(--ink-dim);
				margin-bottom: 2em;
				padding-bottom: 1em;
				border-bottom: 1px solid var(--rule);
			}
			.category-index a {
				color: var(--ink-dim);
				text-decoration: none;
			}
			.category-index a:hover {
				color: var(--accent-bright);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<Sidebar client:load allPosts={allPosts} categoryPosts={categoryPosts} basePath={basePath} />
			<div>
				<nav class="category-index">
					{
						categories.map(({ name }) => (
							<a href={`#category-${encodeURIComponent(name)}`}>{name}</a>
						))
					}
				</nav>
				<CategoryGrid client:load categories={categories} basePath={basePath} />
			</div>
		</main>
		<Footer />
	</body>
</html>
