---
import { getAllCategories } from '../lib/categories';

interface Props {
	active: 'all' | string;
}

const { active } = Astro.props;
const categories = await getAllCategories();
---

<nav class="category-tabs">
	<a href={`${import.meta.env.BASE_URL}texts/`} class:list={[{ active: active === 'all' }]}>
		전체글
	</a>
	{
		categories.map(({ name }) => (
			<a
				href={`${import.meta.env.BASE_URL}texts/${name}/`}
				class:list={[{ active: active === name }]}
			>
				{name}
			</a>
		))
	}
</nav>

<style>
	.category-tabs {
		display: flex;
		flex-wrap: wrap;
		gap: 1.5em;
		padding-bottom: 1em;
		margin-bottom: 1.5em;
		border-bottom: 1px solid var(--rule);
	}
	.category-tabs a {
		font-family: var(--font-sans);
		font-size: 0.9em;
		letter-spacing: 0.04em;
		color: var(--ink-dim);
		text-decoration: none;
		padding-bottom: 0.3em;
		border-bottom: 2px solid transparent;
	}
	.category-tabs a.active {
		color: var(--ink);
		border-bottom-color: var(--accent-bright);
	}
	.category-tabs a:hover {
		color: var(--ink);
	}
</style>
